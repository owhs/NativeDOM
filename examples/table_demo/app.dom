<import src="../components/DefaultTitlebar.dom" as="DefaultTitlebar" />
<import src="../components/Table.dom" as="Table" />

<style>
    ui {
        bg: #11111B;
        font-family: Segoe UI, sans-serif;
        color: #CDD6F4;
    }
    .app-title {
        color: #CBA6F7;
        font-size: 20;
        font-weight: bold;
        padding-top: 2;
    }
    .app-subtitle {
        color: #585B70;
        font-size: 12;
        padding-top: 8;
    }
    .entry-badge {
        bg: #1E1E2E;
        border: #313244;
        border-radius: 12;
        color: #A6E3A1;
        font-size: 11;
        font-weight: bold;
        text-align: center;
        vertical-align: center;
        padding-left: 10;
        padding-right: 10;
    }
    .search-box {
        bg: #181825;
        border: #313244;
        border-radius: 6;
        color: #BAC2DE;
        font-size: 13;
        padding-left: 10;
        padding-top: 7;
        cursor: text;
        white-space: nowrap;
        overflow: hidden;
    }
    .search-box:hover {
        border: #45475A;
    }
    .search-box:focused {
        border: #89B4FA;
    }
    .header-bar {
        bg: #181825;
        border-radius: 8 8 0 0;
    }
    .table-body {
        bg: #11111B;
        overflow: hidden;
    }
    .footer-bar {
        bg: #181825;
        border-radius: 0 0 8 8;
        border: #1E1E2E;
    }
</style>

<ui frameless="true" width="1060" height="700" id="app" title="Table Demo - NativeDOM" onLoad="onAppLoad();">

    <DefaultTitlebar id="titlebar" title="Table Demo — Employee Database (5,000 rows)" />

    <!-- Title Bar Area -->
    <Text class="app-title" x="28" y="40" width="250" height="28" text="Employee Database" />
    <Text class="app-subtitle" x="28" y="64" width="500" height="18" text="5,000 records • sortable • paginated • NativeDOM engine" />

    <!-- Entry Count Badge -->
    <View class="entry-badge" x="880" y="42" width="150" height="26">
        <Text id="entry-badge-text" text="5,000 entries" width="150" height="26" text-align="center" vertical-align="center" font-size="11" color="#A6E3A1" pointer-events="none" />
    </View>

    <!-- Search Box -->
    <View id="search-container" class="search-box" x="660" y="42" width="200" height="26" tabindex="0" onKey="handleSearchKey();">
        <Text id="search-text" text="Type to search..." width="190" height="26" font-size="12" color="#585B70" padding-left="8" padding-top="7" pointer-events="none" white-space="nowrap" overflow="hidden" />
    </View>

    <!-- ===== TABLE ===== -->

    <!-- Header Row -->
    <View id="thead" class="header-bar" x="28" y="92" width="1004" height="32" layout="row">
        <Text id="h0" class="th" width="55"  height="32" text="#" onClick="sortByCol(0);" />
        <Text id="h1" class="th" width="190" height="32" text="Name" onClick="sortByCol(1);" />
        <Text id="h2" class="th" width="265" height="32" text="Email" onClick="sortByCol(2);" />
        <Text id="h3" class="th" width="155" height="32" text="Department" onClick="sortByCol(3);" />
        <Text id="h4" class="th" width="130" height="32" text="Salary" onClick="sortByCol(4);" />
        <Text id="h5" class="th" width="115" height="32" text="Status" onClick="sortByCol(5);" />
    </View>

    <!-- Divider -->
    <View x="28" y="124" width="1004" height="1" bg="#313244" pointer-events="none" />

    <!-- Table Body (pre-allocated rows for maximum reliability) -->
    <View id="tbody" class="table-body" x="28" y="125" width="1004" height="520" layout="col">
        <View id="r0" class="trow" width="1004" height="26" layout="row">
