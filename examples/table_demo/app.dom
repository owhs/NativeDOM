        <View class="page-btn" width="32" height="26" onClick="goLast();">
            <Text text="»" width="32" height="26" text-align="center" vertical-align="center" font-size="14" color="#BAC2DE" pointer-events="none" />
        </View>
    </View>

</ui>

<script>
    /* ==============================================
    Table Demo - Employee Database
    5000 rows, sortable columns, pagination, search
    ============================================== */

    var FIRST_NAMES = ["James","Mary","Robert","Patricia","John","Jennifer","Michael","Linda","David","Elizabeth","William","Barbara","Richard","Susan","Joseph","Jessica","Thomas","Sarah","Christopher","Karen","Daniel","Lisa","Matthew","Nancy","Anthony","Betty","Mark","Margaret","Donald","Sandra"];
    var LAST_NAMES = ["Smith","Johnson","Williams","Brown","Jones","Garcia","Miller","Davis","Rodriguez","Martinez","Hernandez","Lopez","Gonzalez","Wilson","Anderson","Thomas","Taylor","Moore","Jackson","Martin","Lee","Perez","Thompson","White","Harris","Sanchez","Clark","Ramirez","Lewis","Robinson"];
    var DEPARTMENTS = ["Engineering","Marketing","Sales","HR","Finance","Operations","Legal","Design","Support","Research"];
    var STATUSES = ["Active","Active","Active","Active","Inactive","On Leave"];
    var DOMAINS = ["company.com","corp.net","techfirm.io","globalinc.co","startup.dev"];
    var COL_NAMES = ["#","Name","Email","Department","Salary","Status"];

    var allData = [];
    var filteredData = [];
    var currentPage = 0;
    var PAGE_SIZE = 20;
    var sortColumn = 0;
    var sortAscending = true;
    var searchQuery = "";
    var searchActive = false;

    /* -- Cached DOM references for speed -- */
    var rowEls = [];
    var cellEls = [];
    var headerEls = [];

    function cacheElements() {
        var i = 0;
        var j = 0;
        for (i = 0; i < PAGE_SIZE; i++) {
            rowEls.push(document.getElementById("r" + i));
            var cells = [];
            for (j = 0; j < 6; j++) {
                cells.push(document.getElementById("c" + i + "_" + j));
            }
            cellEls.push(cells);
        }
        for (i = 0; i < 6; i++) {
            headerEls.push(document.getElementById("h" + i));
        }
    }

    /* -- Data Generation -- */
    function generateData() {
        var i = 0;
        for (i = 0; i < 5000; i++) {
            var fnIdx = i % 30;
            var lnIdx = ((i * 7) + Math.floor(i / 30)) % 30;
            var fn = FIRST_NAMES[fnIdx];
            var ln = LAST_NAMES[lnIdx];
            var name = fn + " " + ln;
            var emailNum = i > 0 ? "" + i : "";
            var email = fn.toLowerCase() + "." + ln.toLowerCase() + emailNum + "@" + DOMAINS[i % 5];
            var dept = DEPARTMENTS[i % 10];
            var salary = 38000 + ((i * 997 + i * i) % 112000);
            var status = STATUSES[i % 6];
            allData.push([i + 1, name, email, dept, salary, status]);
        }
        /* Start with a copy */
        filteredData = [];
        for (i = 0; i < allData.length; i++) {
            filteredData.push(allData[i]);
        }
    }

    /* -- Sorting -- */
    function sortData() {
        var col = sortColumn;
        var asc = sortAscending;
        var isNumeric = (col === 0 || col === 4);

        filteredData.sort(function(a, b) {
            var va = a[col];
            var vb = b[col];
            if (isNumeric) {
                return asc ? va - vb : vb - va;
            }
            var sa = "" + va;
            var sb = "" + vb;
            if (sa < sb) return asc ? -1 : 1;
            if (sa > sb) return asc ? 1 : -1;
            return 0;
        });
    }

    /* -- Rendering -- */
    function renderPage() {
        var start = currentPage * PAGE_SIZE;
        var totalPages = Math.ceil(filteredData.length / PAGE_SIZE);
        if (totalPages < 1) totalPages = 1;

        var i = 0;
        for (i = 0; i < PAGE_SIZE; i++) {
            var dataIdx = start + i;
            var rowEl = rowEls[i];
            if (!rowEl) continue;

            if (dataIdx < filteredData.length) {
                rowEl.show();
                var row = filteredData[dataIdx];

                /* Set cell text */
                var j = 0;
                for (j = 0; j < 6; j++) {
                    var cell = cellEls[i][j];
                    if (!cell) continue;

                    if (j === 4) {
                        /* Format salary with $ */
                        cell.setAttribute("text", "$" + row[j]);
                    } else {
                        cell.setAttribute("text", "" + row[j]);
                    }
                }

                /* Status color */
                var statusCell = cellEls[i][5];
                if (statusCell) {
                    var st = row[5];
                    if (st === "Active") {
                        statusCell.setAttribute("color", "#A6E3A1");
                    } else if (st === "Inactive") {
                        statusCell.setAttribute("color", "#F38BA8");
                    } else {
                        statusCell.setAttribute("color", "#FAB387");
                    }
                }

                /* Alternating row bg */
                if (i % 2 === 0) {
                    rowEl.setAttribute("bg", "#13132B");
                } else {
                    rowEl.setAttribute("bg", "#16162E");
                }

            } else {
                rowEl.hide();
            }
        }

        /* Update pagination info */
        var pageInfo = document.getElementById("page-info");
        if (pageInfo) {
            var showing = start + 1;
            var showEnd = start + PAGE_SIZE;
            if (showEnd > filteredData.length) showEnd = filteredData.length;
            if (filteredData.length === 0) showing = 0;
            pageInfo.setAttribute("text",
            "Page " + (currentPage + 1) + " of " + totalPages +
            "  •  Showing " + showing + "-" + showEnd +
            " of " + filteredData.length
            );
        }

        /* Update header sort indicators */
        updateHeaders();
    }

    function updateHeaders() {
        var i = 0;
        for (i = 0; i < 6; i++) {
            var hEl = headerEls[i];
            if (!hEl) continue;
            var name = COL_NAMES[i];
            if (i === sortColumn) {
                var arrow = sortAscending ? " ▲" : " ▼";
                hEl.setAttribute("text", name + arrow);
                hEl.setAttribute("color", "#89B4FA");
                hEl.setAttribute("bg", "#252545");
            } else {
                hEl.setAttribute("text", name);
                hEl.setAttribute("color", "#7F849C");
                hEl.setAttribute("bg", "#1A1A2E");
            }
        }
    }

    /* -- Column Sort Handler -- */
    function sortByCol(col) {
        if (col === sortColumn) {
            sortAscending = !sortAscending;
        } else {
            sortColumn = col;
            sortAscending = true;
        }
        sortData();
        currentPage = 0;
        renderPage();
    }

    /* -- Pagination -- */
    function goFirst() {
        currentPage = 0;
        renderPage();
    }
    function goPrev() {
        if (currentPage > 0) {
            currentPage = currentPage - 1;
            renderPage();
        }
    }
    function goNext() {
        var totalPages = Math.ceil(filteredData.length / PAGE_SIZE);
        if (currentPage < totalPages - 1) {
            currentPage = currentPage + 1;
            renderPage();
        }
    }
    function goLast() {
        var totalPages = Math.ceil(filteredData.length / PAGE_SIZE);
        currentPage = totalPages - 1;
        if (currentPage < 0) currentPage = 0;
        renderPage();
    }

    /* -- Search / Filter -- */
    function applySearch() {
        if (searchQuery === "") {
            filteredData = [];
            var k = 0;
            for (k = 0; k < allData.length; k++) {
                filteredData.push(allData[k]);
            }
        } else {
            filteredData = [];
            var q = searchQuery.toLowerCase();
            var i = 0;
            for (i = 0; i < allData.length; i++) {
                var row = allData[i];
                var match = false;
                var j = 0;
                for (j = 0; j < 6; j++) {
                    var cellStr = ("" + row[j]).toLowerCase();
                    if (cellStr.indexOf(q) >= 0) {
                        match = true;
                        break;
                    }
                }
                if (match) filteredData.push(row);
            }
        }
        sortData();
        currentPage = 0;
        renderPage();

        /* Update badge */
        var badge = document.getElementById("entry-badge-text");
        if (badge) {
            badge.setAttribute("text", filteredData.length + " entries");
        }
    }

    function handleSearchKey() {
        var kc = sys.event.keyCode;
        var searchTextEl = document.getElementById("search-text");
        if (!searchTextEl) return;

        if (!searchActive) {
            searchActive = true;
            searchQuery = "";
            searchTextEl.setAttribute("text", "");
            searchTextEl.setAttribute("color", "#CDD6F4");
        }

        if (kc === 8) {
            /* Backspace */
            if (searchQuery.length > 0) {
                searchQuery = searchQuery.slice(0, -1);
            }
        } else if (kc === 27) {
            /* Escape - clear search */
            searchQuery = "";
            searchActive = false;
            searchTextEl.setAttribute("text", "Type to search...");
            searchTextEl.setAttribute("color", "#585B70");
            applySearch();
            return;
        } else if (kc >= 32 && kc <= 126) {
            searchQuery = searchQuery + String.fromCharCode(kc);
        } else {
            return;
        }

        if (searchQuery.length === 0) {
            searchTextEl.setAttribute("text", "|");
        } else {
            searchTextEl.setAttribute("text", searchQuery + "|");
        }
        applySearch();
    }

    /* -- Main Init -- */
    function onAppLoad() {
        sys.log("Table Demo: Generating 5000 records...");
        cacheElements();
        generateData();
        sortData();
        renderPage();
        sys.log("Table Demo: Ready. " + allData.length + " records loaded.");
        sys.window.center();
    }
</script>
